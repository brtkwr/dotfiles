  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c \"if (.tool_input.skill // \\\"\\\") == \\\"two-slack:two-slack-operations\\\" then {hookSpecificOutput:{hookEventName:\\\"PreToolUse\\\",additionalContext:\\\"Review requests route by Linear ticket prefix \\\\u2014 PLAT-* \\\\u2192 #control-plane (C09J5J4NFR6), PERF-* \\\\u2192 C0B9ZAL1USF, ISEC-* \\\\u2192 #control-plane. NEVER #tech-platform for reviews. Source of truth: ~/.claude/projects/-Users-brtkwr-Code-two-inc/memory/reference_two_review_channel.md. Pass the exact channel ID; do not let the skill guess.\\\"}} else empty end\"",
            "statusMessage": "Checking review-channel routing"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{hookSpecificOutput:{hookEventName:\"PreToolUse\",additionalContext:\"Delegation priority (from ~/.claude/CLAUDE.md): 1) codex exec (gpt-5.6-sol) 2) cswap run 3) in-session Agent. Use the Agent tool only for forks of this session, Claude-only skills/MCP, Workflow fan-outs, or when codex/cswap runs are failing. Recipes: reference_codex_delegation / reference_cswap_delegation memories. If proceeding with Agent, that is fine when justified - this is a reminder, not a block.\"}}'",
            "statusMessage": "Delegation-priority reminder"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/brtkwr/.claude/hooks/nudge-worktree-for-feature-branch.sh",
            "statusMessage": "Checking for feature-branch git op outside worktree"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/brtkwr/.claude/hooks/arm-watch-pipelines-after-pr.sh",
            "statusMessage": "Checking for new PR to arm watch-pipelines"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/brtkwr/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true,
